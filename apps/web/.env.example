# =============================================================================
# OrbitForm Web — local development (do not commit)
# Copy: cp apps/web/.env.example apps/web/.env
# Used by: apps/web (Next.js loads this automatically)
# =============================================================================

# Browser must call same-origin /trpc so auth cookies are first-party.
# Do not set this to an external API origin in production.
NEXT_PUBLIC_API_URL=/trpc

# Server-side rewrite target (no trailing slash).
API_INTERNAL_URL=http://localhost:8000

# --- Build (optional) ---
# SKIP_ENV_VALIDATION=1
