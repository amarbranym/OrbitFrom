# =============================================================================
# OrbitForm environment variables
# Copy: cp .env.example .env
# Used by: pnpm dev, pnpm db:migrate (dotenv loads this file at repo root)
# =============================================================================

# --- Supabase (recommended for production) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Transaction pooler (app runtime — port 6543, pgbouncer=true)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session pooler (migrations only — port 5432)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- Auth (required — @repo/services) ---
# Min 32 characters. Generate: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# --- API server (@repo/api) ---
PORT=8000
BASE_URL=http://localhost:8000
NODE_ENV=development
WEB_URL=http://localhost:3000

# --- Next.js web (apps/web) ---
# Proxied to API via next.config rewrites when set to /trpc
NEXT_PUBLIC_API_URL=/trpc
API_INTERNAL_URL=http://localhost:8000

# --- Logging (@repo/logger, optional) ---
# LOGGER_LEVEL=info

# --- Demo (optional — fixed OTP for judge/demo login) ---
# DEMO_OTP_CODE=000000

# --- Email OTP (optional — without SMTP, codes print in API terminal) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@orbitform.app

# --- Google OAuth (optional — email OTP works without these) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Build (optional) ---
# SKIP_ENV_VALIDATION=1
