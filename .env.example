# =============================================================================
# OrbitForm uses split environment files — do not put secrets here.
# =============================================================================
#
# Local setup:
#   cp apps/api/.env.example apps/api/.env
#   cp apps/web/.env.example apps/web/.env
#   # Edit apps/api/.env (database, SESSION_SECRET, SMTP, etc.)
#   pnpm db:migrate
#   pnpm dev
#
# See:
#   apps/api/.env.example  — API, database, auth, email
#   apps/web/.env.example  — Next.js public API URL + rewrite target
#
# Production (Vercel):
#   API project  → variables from apps/api/.env.example
#   Web project  → variables from apps/web/.env.example
#
