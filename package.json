{
  "name": "orbitform",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=web --filter=@repo/api",
    "db:generate": "dotenv -e apps/api/.env -- turbo db:generate",
    "db:migrate": "dotenv -e apps/api/.env -- turbo db:migrate",
    "db:check": "dotenv -e apps/api/.env -- pnpm --filter @repo/database exec tsx scripts/test-db.ts",
    "db:seed": "dotenv -e apps/api/.env -- turbo db:seed",
9    "setup": "pnpm db:migrate",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
